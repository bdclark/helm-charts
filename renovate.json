{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "customManagers:helmChartYamlAppVersions"],
  "packageRules": [
    {
      "matchPackageNames": ["linuxserver/qbittorrent"],
      "allowedVersions": "/^[0-9]\\.[0-9]+\\.[0-9]+$/"
    },
    {
      "description": "Bump chart version patch when Renovate updates chart app/image references",
      "matchManagers": ["custom.regex", "helm-values"],
      "matchFileNames": ["charts/**/Chart.yaml", "charts/**/values.yaml"],
      "bumpVersions": [
        {
          "name": "Helm chart version patch bump",
          "filePatterns": ["{{packageFileDir}}/Chart.yaml"],
          "matchStrings": ["^version:\\s*\"?(?<version>\\d+\\.\\d+\\.\\d+)\"?\\s*$"],
          "bumpType": "patch"
        }
      ]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^\\.github/versions\\.env$"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>.*?)\\s+depName=(?<depName>.*?)\\n[A-Z_]+=(?<currentValue>.*)"
      ],
      "extractVersionTemplate": "^v?(?<version>.*)$"
    }
  ]
}
